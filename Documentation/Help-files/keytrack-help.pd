#X connect 1 0 4 0;
#X connect 2 0 5 0;
#X connect 2 0 11 0;
#X connect 4 0 3 0;
#X connect 5 0 6 0;
#X connect 6 0 4 0;
#X connect 14 0 15 0;
#X connect 14 0 4 1;
